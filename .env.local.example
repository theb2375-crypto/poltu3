# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the real values.
# .env.local is git-ignored, so your keys stay private.
# ---------------------------------------------------------------------------

# --- Firebase web config ---------------------------------------------------
# Firebase Console -> Project settings (gear) -> "Your apps" -> Web app.
# These are PUBLIC values (safe in the browser bundle).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Gemini (free AI key for the chatbot) ----------------------------------
# Get it at https://aistudio.google.com/apikey  (starts with "AIza...").
# This is a SECRET — never commit the real value.
GOOGLE_GENERATIVE_AI_API_KEY=
